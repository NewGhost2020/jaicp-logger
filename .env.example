# Реестр ботов: каждый бот — свой токен и отображаемое имя.
# Токен жёстко привязан к bot_id (подделать чужой bot_id при ingest нельзя).
# Добавить бота = сгенерировать токен (python -c "import secrets; print(secrets.token_hex(32))")
# и дописать сюда новую запись.
BOT_TOKENS={"tema-bot": {"token": "change_me_to_secret_token", "name": "Тёма (Telematika)"}}

# Legacy общий токен (wildcard, разрешает любой bot_id). Оставлять пустым, кроме периода миграции.
LOG_INGEST_TOKEN=
BASIC_AUTH_USER=igor
BASIC_AUTH_PASS_HASH=$2b$12$change_me_to_bcrypt_hash
DATABASE_URL=sqlite+aiosqlite:///data/jaicp_logs.db
TZ_DISPLAY=Europe/Moscow
SESSION_ABANDON_HOURS=2
RETENTION_DAYS=30
BATCHES_RETENTION_DAYS=7
